@InCollection{Carpio2022,
  author    = {Ana Carpio and Emile Pierret},
  booktitle = {Mathematical Analysis of Infectious Diseases},
  publisher = {Academic Press},
  title     = {Chapter 7 - Parameter identification in epidemiological models},
  year      = {2022},
  editor    = {Praveen Agarwal and Juan J. Nieto and Delfim F.M. Torres},
  isbn      = {978-0-323-90504-6},
  pages     = {103-124},
  abstract  = {We develop a Bayesian inference framework to estimate parameters in epidemiological models with quantified uncertainty. We consider SEIJR models involving populations of susceptible, exposed, infective, diagnosed, dead, and recovered individuals, and infer from data all the parameter models, in particular, the transmission and recovery rates. We exemplify the procedure using Covid-19 data from Spain since the onset of the current pandemic. Successive nonpharmaceutical actions such as lockdowns, distancing, and release of mobility restrictions, define stages in the data which are reflected in the parameter values. Tracking the evolution of the different populations with time, we can infer the evolution of the total fraction of subjects affected by the virus, including asymptomatic individuals. Using the resulting models as constraints in optimization problems for adequate costs we can gain insight on the parameter regimes in which the epidemic would remain controlled, even when migration effects are included.},
  doi       = {https://doi.org/10.1016/B978-0-32-390504-6.00012-7},
  keywords  = {SEIJR models, parameter identification, constrained optimization, Bayesian inference, uncertainty quantification},
  url       = {https://www.sciencedirect.com/science/article/pii/B9780323905046000127},
}

@InCollection{Prodanov2022,
  author    = {Dimiter Prodanov},
  booktitle = {Mathematical Analysis of Infectious Diseases},
  publisher = {Academic Press},
  title     = {Chapter 10 - Analytical solutions and parameter estimation of the SIR epidemic model},
  year      = {2022},
  editor    = {Praveen Agarwal and Juan J. Nieto and Delfim F.M. Torres},
  isbn      = {978-0-323-90504-6},
  pages     = {163-189},
  abstract  = {The SIR (Susceptible-Infected-Removed) model is a simple mathematical model of epidemic outbreaks, yet for decades it evaded the efforts of the community to derive an explicit solution. The present manuscript surveys new analytical results about the SIR model. Recently, it was proven that the explicit solution of the model requires the introduction of a new transcendental special function, related to the Wright's Omega function and Lambert W function. Asymptotic methods and iterative numerical routines suitable for parametric estimation of the SIR model are discussed as well. The methods are exemplified with influenza and COVID-19 datasets.},
  doi       = {https://doi.org/10.1016/B978-0-32-390504-6.00015-2},
  keywords  = {SIR model, special functions, Lambert W function, Wright Omega function},
  url       = {https://www.sciencedirect.com/science/article/pii/B9780323905046000152},
}

@InProceedings{Huu2025,
  author    = {Huu, Van Long Nguyen and Chau, Kim Khuyen},
  booktitle = {Software Engineering: Emerging Trends and Practices in System Development},
  title     = {Enhancing Computer Network Learning with Hands-on Lab Exercises},
  year      = {2025},
  address   = {Cham},
  editor    = {Silhavy, Radek and Silhavy, Petr},
  pages     = {327--338},
  publisher = {Springer Nature Switzerland},
  abstract  = {Hands-on lab exercises are important in teaching Computer Networking to undergraduate students since they illustrate how theory and practice are together. Using Kathar{\'a}, a lightweight network emulator, is a scalable and cost-effective solution. Integrating Kathar{\'a} into the Computer Networking through a set of proper exercises with different objectives can significantly enhance the teaching and learning performance. Such a kind of work must tackle three main challenges: the diversity of protocols, simplicity of the exercises, and scalability of the networks. Our solution leverages the features of Kathar{\'a} to make hands-on lab exercises more accessible, reproducible, and customizable for the students instead of asking for a strong background in network programming. Our observation during the teaching process concludes that this hands-on lab facilitates the learning of students from different schools, such as information technology, education, and engineering.},
  isbn      = {978-3-032-00712-4},
  url       = {https://doi.org/10.1007/978-3-032-00712-4_22},
}

